{
  "name": {
    "en": "Vartronic Convector"
  },
  "class": "thermostat",
  "connectivity": [
    "lan"
  ],
  "capabilities": [
    "target_temperature",
    "measure_temperature",
    "alarm_generic",
    "vartronic_heat_valve_open",
    "vartronic_mode",
    "vartronic_fan_mode"
  ],
  "capabilitiesOptions": {
    "target_temperature": {
      "min": 5,
      "max": 35,
      "step": 0.5
    }
  },
  "images": {
    "small": "/drivers/vartronic_convector/assets/images/small.png",
    "large": "/drivers/vartronic_convector/assets/images/large.png"
  },
  "pair": [
    {
      "id": "configure_gateway"
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "repair": [
    {
      "id": "update_gateway"
    }
  ],
  "settings": [
    {
      "id": "host",
      "type": "text",
      "label": {
        "en": "Gateway host"
      },
      "hint": {
        "en": "Changing this value updates all devices that share the same gateway key."
      }
    },
    {
      "id": "port",
      "type": "number",
      "label": {
        "en": "Gateway port"
      }
    },
    {
      "id": "pollingIntervalSec",
      "type": "number",
      "label": {
        "en": "Polling interval"
      },
      "hint": {
        "en": "Heartbeat interval in seconds for all devices on this gateway. Keep it no greater than half of the lowest controller TimeLan."
      },
      "value": 5
    },
    {
      "id": "disableThermostatModeOnLan",
      "type": "checkbox",
      "label": {
        "en": "Force fan-off flag on mode writes"
      },
      "hint": {
        "en": "Sets the 0x0100 HeatChill fan-disable flag. Usually leave this off and use Fan mode Off instead."
      },
      "value": false
    },
    {
      "id": "forceFanControlFromNetwork",
      "type": "checkbox",
      "label": {
        "en": "Force fan speed from network"
      },
      "hint": {
        "en": "Sets the 0x0200 HeatChill manual-fan flag on mode writes. Low, Medium, and High fan modes set this automatically."
      },
      "value": false
    }
  ]
}
